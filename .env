# REACT Backend URL
# REACT_APP_API_URL=https://elp-backend-production.up.railway.app
REACT_APP_API_URL=http://localhost:8080

# --- JDoodle Compiler API Credentials ---
# Uncomment and fill in your keys when running locally:
# REACT_APP_JDOODLE_CLIENT_ID="your_jdoodle_client_id_here"
# REACT_APP_JDOODLE_CLIENT_SECRET="your_jdoodle_client_secret_here"
# REACT_APP_JDOODLE_API_URL="https://api.jdoodle.com/v1/execute"
REACT_APP_JDOODLE_API_URL="https://cors-anywhere.herokuapp.com/https://api.jdoodle.com/v1/execute"
# --- Groq Chatbot API Credentials ---
# Uncomment and fill in your key when running locally:
# REACT_APP_GROQ_API_KEY="your_groq_api_key_here"
REACT_APP_GROQ_API_URL="https://api.groq.com/openai/v1/chat/completions"
REACT_APP_GROQ_MODEL="llama-3.3-70b-versatile"